{
  "name": "@cumulus-ui/react-to-lit",
  "version": "0.1.0",
  "description": "Standalone React-to-Lit web component transpiler. Converts React component libraries to Lit web components using TypeScript AST.",
  "type": "module",
  "bin": {
    "react-to-lit": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "typescript": "^5.8.3",
    "commander": "^13.1.0",
    "prettier": "^3.5.3"
  },
  "devDependencies": {
    "vitest": "^3.1.1",
    "@types/node": "^22.14.1"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0"
}
